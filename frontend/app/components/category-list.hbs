{{#if this.hasCategories}}
  {{#if this.expenseCategories.length}}
    <h3 class="section-title">Expense Categories</h3>
    <div class="category-grid">
      {{#each this.expenseCategories as |cat|}}
        <div class="category-card">
          <div class="cat-icon" style="background:{{cat.color}}">{{this.fetchIcon cat.icon}}</div>
          <div class="cat-info">
            <span class="cat-name">{{cat.name}}</span>
            <span class="cat-type type-expense">expense</span>
          </div>
          <button class="btn btn-sm btn-danger"
            {{on "click" (fn this.deleteCategory cat.id)}}>Delete</button>
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{#if this.incomeCategories.length}}
    <h3 class="section-title" style="margin-top: 20px;">Income Categories</h3>
    <div class="category-grid">
      {{#each this.incomeCategories as |cat|}}
        <div class="category-card">
          <div class="cat-icon" style="background:{{cat.color}}">{{this.fetchIcon cat.icon}}</div>
          <div class="cat-info">
            <span class="cat-name">{{cat.name}}</span>
            <span class="cat-type type-income">income</span>
          </div>
          <button class="btn btn-sm btn-danger"
            {{on "click" (fn this.deleteCategory cat.id)}}>Delete</button>
        </div>
      {{/each}}
    </div>
  {{/if}}
{{else}}
  <div class="empty-state">
    <p>No categories yet. Add your first one above!</p>
  </div>
{{/if}}