<div class="auth-card">
    <h2>Login</h2>
    {{#if this.error}}
    <div class="alert alert-error">{{this.error}}</div>
    {{/if}}
    <form {{on "submit" this.handleSubmit}}>
        <div class="form-group">
            {{!-- <label for="emailinput">Email</label> --}}
            <input type="email" value={{this.email}} {{on "input" this.updateEmail}}
            placeholder="Enter your email" class="form-input" required id="emailinput"/>
        </div>
        <div class="form-group">
            {{!-- <label for="passwordinput">Password</label> --}}
            <input type="password" id="passwordinput" value={{this.password}} {{on "input" this.updatePassword}}
            placeholder="Enter your password" class="form-input" required />
        </div>
        <button type="submit" class="btn btn-primary btn-block"
        disabled={{this.isLoading}}>
        {{if this.isLoading "Logging in..." "Login"}}
        </button>
    </form>
    <p class="auth-link">Don't have an account?
    <LinkTo @route="register">Register</LinkTo>
    </p>
</div>