<div class="auth-card">
    <h2>Create Account</h2>
    {{#if this.error}}
    <div class="alert alert-error">{{this.error}}</div>
    {{/if}}
    <form {{on "submit" this.handleSubmit}}>
        <div class="form-group">
            {{!-- <label for="nameinput">Name</label> --}}
            <input id="nameinput" type="text" value={{this.name}} {{on "input" this.updateName}}
            placeholder="Your name" class="form-input" required />
        </div>
        <div class="form-group">
            {{!-- <label for="emailinput">Email</label> --}}
            <input id="emailinput" type="email" value={{this.email}} {{on "input" this.updateEmail}}
            placeholder="Your email" class="form-input" required />
        </div>
        <div class="form-group">
            {{!-- <label for="passwordinput">Password</label> --}}
            <input id="passwordinput" type="password" value={{this.password}} {{on "input" this.updatePassword}}
            placeholder="Min 6 characters" class="form-input" required />
        </div>
        <button type="submit" class="btn btn-primary btn-block"
        disabled={{this.isLoading}}>
        {{if this.isLoading "Creating..." "Register"}}
        </button>
    </form>
    <p class="auth-link">Already have an account?
    <LinkTo @route="login">Login</LinkTo>
    </p>
</div>