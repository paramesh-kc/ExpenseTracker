<nav class="navbar">
  <div class="nav-brand">
    <LinkTo @route="dashboard" class="brand">
      <span>ExpenseTracker</span>
    </LinkTo>
  </div>
  <div class="nav-links">
    <a href="/dashboard" class="nav-link" {{on "click" (fn this.navigate "dashboard")}}>Dashboard</a>
    <a href="/transactions" class="nav-link" {{on "click" (fn this.navigate "transactions")}}>Transactions</a>
    <a href="/categories" class="nav-link" {{on "click" (fn this.navigate "categories")}}>Categories</a>
  </div>
  <div class="nav-user">
    <span class="user-name">{{this.auth.name}}</span>
    <button type="button" class="btn btn-logout" {{on "click" this.logout}}>Logout</button>
  </div>
</nav>